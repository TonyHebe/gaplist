# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Public URL for Open Graph / social previews (set to your Vercel domain)
NEXT_PUBLIC_SITE_URL=https://gaplist.vercel.app

# Cron protection (Vercel sends this as Authorization: Bearer <CRON_SECRET>)
CRON_SECRET=generate-a-long-random-string

# Reddit OAuth (script app) — used when all four are set; otherwise RSS fallback
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USERNAME=GapListBot
REDDIT_PASSWORD=
REDDIT_USER_AGENT=GapList/0.1 (read-only monitor; contact: antoniohebe1@gmail.com)

# Optional — AI category + pain score tagging (falls back to heuristics if unset)
OPENAI_API_KEY=
